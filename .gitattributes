# summer 仓库 Git 属性
# 统一原则：文本文件以 UTF-8（无 BOM）、LF 行尾存储；仅 *.bat 强制 CRLF。

# 默认：自动识别文本文件并以 LF 结尾
* text=auto eol=lf

# 文本源码与配置：LF 行尾、声明 working-tree-encoding=UTF-8（UTF-8 文件为 no-op 声明，便于工具链校验）
*.java          text eol=lf working-tree-encoding=UTF-8
*.xml           text eol=lf working-tree-encoding=UTF-8
*.yml           text eol=lf working-tree-encoding=UTF-8
*.yaml          text eol=lf working-tree-encoding=UTF-8
*.json          text eol=lf working-tree-encoding=UTF-8
*.md            text eol=lf working-tree-encoding=UTF-8
*.properties    text eol=lf working-tree-encoding=UTF-8

# 脚本
*.sh            text eol=lf
*.ps1           text eol=lf
# Windows 批处理必须 CRLF
*.bat           text eol=crlf
*.cmd           text eol=crlf

# 二进制：不做任何转换
*.class         binary
*.jar           binary
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.pdf           binary
*.pub           binary
